# ============================================
# Staging Environment Variables
# Copy to .env.staging and customize
# ============================================

# Application
APP_NAME="Laravel Filament Staging"
APP_ENV=staging
APP_KEY=base64:xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
APP_DEBUG=false
APP_URL=https://staging.example.com

# Database
DB_CONNECTION=mysql
DB_HOST=mysql
DB_PORT=3306
DB_DATABASE=laravel_staging
DB_USERNAME=laravel
DB_PASSWORD=CHANGE_ME
DB_ROOT_PASSWORD=CHANGE_ME_ROOT

# Redis
REDIS_HOST=redis
REDIS_PASSWORD=CHANGE_ME_REDIS
REDIS_PORT=6379

# Cache & Queue
CACHE_DRIVER=redis
QUEUE_CONNECTION=redis
SESSION_DRIVER=redis

# Mail
MAIL_MAILER=smtp
MAIL_HOST=smtp.example.com
MAIL_PORT=587
MAIL_USERNAME=your-email@example.com
MAIL_PASSWORD=CHANGE_ME
MAIL_ENCRYPTION=tls

# Ports
NGINX_PORT=8084

# Monitoring (Optional)
GRAFANA_PASSWORD=CHANGE_ME
