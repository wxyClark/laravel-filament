# ============================================
# Production Environment Variables
# Copy to .env.prod and customize
# NEVER commit this file to version control!
# ============================================

# Application
APP_NAME="Laravel Filament"
APP_ENV=production
APP_KEY=base64:GENERATE_WITH_php_artisan_key_generate
APP_DEBUG=false
APP_URL=https://www.example.com

# Database
DB_CONNECTION=mysql
DB_HOST=mysql
DB_PORT=3306
DB_DATABASE=laravel_production
DB_USERNAME=laravel_prod_user
DB_PASSWORD=STRONG_PASSWORD_HERE
DB_ROOT_PASSWORD=STRONG_ROOT_PASSWORD_HERE

# Redis
REDIS_HOST=redis
REDIS_PASSWORD=STRONG_REDIS_PASSWORD_HERE
REDIS_PORT=6379

# Cache & Queue
CACHE_DRIVER=redis
QUEUE_CONNECTION=redis
SESSION_DRIVER=redis

# Mail
MAIL_MAILER=smtp
MAIL_HOST=smtp.example.com
MAIL_PORT=587
MAIL_USERNAME=noreply@example.com
MAIL_PASSWORD=STRONG_MAIL_PASSWORD_HERE
MAIL_ENCRYPTION=tls

# Ports
NGINX_PORT=80
NGINX_SSL_PORT=443

# Monitoring (Optional)
GRAFANA_PASSWORD=STRONG_GRAFANA_PASSWORD_HERE
PROMETHEUS_PORT=9090
GRAFANA_PORT=3000

# JWT Secret (for API authentication)
JWT_SECRET=GENERATE_WITH_php_artisan_jwt_secret
